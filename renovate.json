{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["nix/packages/.+\\.nix$"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)\\n\\s*\\{\\s*attr\\s*=\\s*\"[^\"]*\"\\s*;\\s*version\\s*=\\s*\"(?<currentValue>[^\"]*)\"\\s*;\\s*\\}"
      ],
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
